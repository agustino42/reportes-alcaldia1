generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  role      String     @default("CITIZEN") // CITIZEN, ADMIN, TECHNICIAN
  password  String?    // Enabled for password login
  avatar    String?    // Avatar URL or initials
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  incidents Incident[]
  comments  Comment[]
  votes     Vote[]
}

model Incident {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String?
  category    String   @default("OTRO") // VIALIDAD, AGUA, LUZ, ASEO, etc.
  status      String   @default("RECIBIDO") // RECIBIDO, EN_REVISION, COMPLETADO
  trackerCode String   @unique // Short code for citizen traceability

  citizenDni   String?  // Cedula
  citizenName  String?
  citizenPhone String?

  imageUrl       String?  // Photo evidence (Supabase Storage)
  assignedDepartment String?  // Department assigned to handle
  assignedTo     String?  // Person/team assigned
  notes          String?  // Internal notes
  publishedAt    DateTime? // When admin published to frontend (null = not shown)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  comments    Comment[]
  votes       Vote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id         String    @id @default(uuid())
  content    String
  incidentId String
  incident   Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String?   // Display name (citizen name or admin name)

  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Vote {
  id         String   @id @default(uuid())
  value      Int      // 1 (upvote), -1 (downvote)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, incidentId])
}

model Employee {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?
  position      String   // Position/Role in the organization
  academicLevel String?  // Academic level: Bachiller, TSU, Universitario, Postgrado
  department    String   // Department assignment
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  hireDate      DateTime @default(now())
  salary        Float?    // Optional salary information
  address       String?   // Employee address
  avatar        String?   // Profile picture URL
  supervisorId  String?  // Reference to supervisor
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

